# ─── Copy this file to .env and fill in the values ───────────────
# cp .env.example .env

# MongoDB password (เลือกรหัสผ่านที่แข็งแรง)
MONGO_PASSWORD=your-strong-mongo-password-here

# JWT Secret (สุ่มจาก: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# VPS IP address (ใส่ IP ของ VPS Hostinger)
VPS_IP=xxx.xxx.xxx.xxx
