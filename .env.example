# ─── Copy this file to .env and fill in the values ───────────────
# cp .env.example .env

# ─── VPS / Domain Setup ───────────────
# localhost   = ทดสอบบนเครื่อง
# 103.xx.x.x  = IP VPS (ถ้ายังไม่มี domain)
# app.planeat.com = domain จริง (แนะนำ)
VPS_IP=localhost

# Domain หลักของระบบ (ใช้สำหรับสร้าง webhook URL ใน LINE)
# ตัวอย่าง: https://app.planeat.com
APP_DOMAIN=http://localhost:8001

# รายชื่อ Domain/URL ทั้งหมดที่อนุญาตให้ดึงข้อมูล (คั่นด้วยคอมม่า)
# localhost:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8001
# production (เพิ่มต่อท้าย):
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.planeat.com

# ─── Database & Auth ───────────────
MONGO_PASSWORD=your-mongo-password-here
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── SMTP Email Settings (สำหรับรับส่ง OTP) ───────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# ─── Redis (ARQ Worker + Caching) ───────────────
# ใน Docker ใช้ redis://redis:6379 | บน VPS ตรงๆ ใช้ redis://localhost:6379
REDIS_URL=redis://redis:6379

# ─── PDF Storage ───────────────
# Path ภายใน container (map กับ docker volume pdf_data)
PDF_STORAGE_PATH=/app/pdf_storage

# ─── Logging ───────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
